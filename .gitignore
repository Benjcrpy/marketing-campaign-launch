# Dependencies
node_modules/

# Next.js (build output — never commit)
.next
**/.next
out/
*.tsbuildinfo

# Environment (use .env.example as template)
.env
.env.local
.env.*.local

# Local secrets
config/credentials.json

# Hermes runtime state (Docker / local; recreated on run)
hermes-data/*
!hermes-data/.gitkeep

# OS / editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
